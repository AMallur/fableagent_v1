# Copy to .env and fill in real values. .env is gitignored — never commit it.
#
# Generate strong random values for the two secrets, e.g.:
#   openssl rand -hex 32

# --- local docker-compose Postgres (dev/staging only — see docker-compose.yml) ---
POSTGRES_PASSWORD=

# --- Cloud SQL (HA, automated backups) instead of local Postgres — only used
#     by docker-compose.cloudsql.yml, not the default docker-compose.yml.
#     Provision first: PROJECT_ID=... DB_PASSWORD=... bash db/provision_cloudsql.sh
#     which prints these two values. ---
CLOUDSQL_INSTANCE_CONNECTION_NAME=
CLOUDSQL_PASSWORD=

# --- required in production; the app refuses to boot without these ---
SESSION_SECRET=
DATA_ENCRYPTION_KEY=

# --- Caddy's TLS certificate is issued for this domain ---
DOMAIN=

# --- SMTP: leave blank until a BAA is signed with your email provider.
#     Notifications will be logged instead of delivered until this is set. ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# --- Document storage: leave blank to use local disk (fine for one instance
#     with a persistent volume; not fine once you run more than one). Set
#     GCS_DOCUMENT_BUCKET to move appeal packets/letters to Cloud Storage.
#     On GCE, leave GOOGLE_APPLICATION_CREDENTIALS blank too — the VM's
#     attached service account is used automatically. Elsewhere, point it at
#     a mounted service-account key file. ---
GCS_DOCUMENT_BUCKET=
GOOGLE_APPLICATION_CREDENTIALS=
